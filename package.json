{
	"name": "flacscan",
	"version": "1.0.1",
	"description": "Periodic integrity verification for large FLAC collections",
	"type": "module",
	"bin": {
		"flacscan": "./dist/index.mjs"
	},
	"engines": {
		"node": ">=22"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/xysnaptic/flacscan.git"
	},
	"files": [
		"dist",
		"flacscan.config.example.yaml"
	],
	"scripts": {
		"dev": "tsx src/index.ts",
		"build": "tsdown",
		"format": "prettier --write .",
		"lint": "eslint . --fix",
		"check": "eslint . && knip && tsc --noEmit && vitest run",
		"check-types": "tsc --noEmit",
		"knip": "knip",
		"test": "vitest run",
		"prebuild": "pnpm check",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"better-sqlite3": "^12.6.2",
		"chalk": "^5.4.1",
		"citty": "^0.2.1",
		"ora": "^9.3.0",
		"yaml": "^2.7.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild"
		]
	},
	"knip": {
		"vitest": {
			"entry": [
				"tests/**/*.test.ts"
			]
		}
	},
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.3.3",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-perfectionist": "^5.6.0",
		"eslint-plugin-unicorn": "^63.0.0",
		"jiti": "^2.6.1",
		"knip": "^5.85.0",
		"prettier": "^3.8.1",
		"tsdown": "^0.20.3",
		"tsx": "^4.19.3",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.0.18"
	}
}
